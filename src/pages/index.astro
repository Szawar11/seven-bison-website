---
import BaseLayout from '@layouts/BaseLayout.astro';
import Hero from '@components/home/Hero.astro';
import TrustStrip from '@components/home/TrustStrip.astro';
import EndToEndPartner from '@components/home/EndToEndPartner.astro';
import ServicesStrip from '@components/home/ServicesStrip.astro';
import SectorCards from '@components/home/SectorCards.astro';
import HowWeWork from '@components/home/HowWeWork.astro';
import Section from '@components/ui/Section.astro';
import Button from '@components/ui/Button.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import { contact } from '@lib/config';
---

<BaseLayout
  title="Industry-specific video craft and art, delivered at scale"
  description="Premium video, motion design and animation for B2B brands with complex, regulated, or hard-to-photograph subject matter."
>
  <!-- §4.1 Hero -->
  <Hero />

  <!-- §4.3 Trust strip -->
  <TrustStrip />

  <!-- §4.2 End-to-end partner -->
  <EndToEndPartner />

  <!-- §4.4 Services strip -->
  <ServicesStrip />

  <!-- §4.5 Three industries — most important block -->
  <SectorCards />

  <!--
    §4.6 Selected work mosaic — TODO
    Build out a 6–9 piece grid that autoplays on hover and opens a Vimeo modal or case study.
  -->
  <Section spacing="loose">
    <Eyebrow>05 · Selected work</Eyebrow>
    <h2 class="mt-3 max-w-readable">Less noise. More signal.</h2>
    <p class="mt-4 max-w-readable text-body text-gray">
      <!-- Replace this block with the work mosaic component once reels are in. -->
      Mosaic of six to nine selected pieces goes here. Autoplay on hover.
      Click opens a case study or Vimeo modal.
    </p>
  </Section>

  <!-- §4.7 How we work -->
  <HowWeWork />

  <!--
    §4.8 Testimonials — TODO
    3–4 strongest testimonials, sector-balanced. Written quotes with attribution.
  -->
  <Section spacing="loose">
    <Eyebrow>07 · Testimonials</Eyebrow>
    <h2 class="mt-3 max-w-readable">Built for ongoing partnerships.</h2>
    <p class="mt-4 max-w-readable text-body text-gray">
      Quotes from clients on long-term work go here. Sector-balanced. Three to four
      strongest written testimonials with full attribution.
    </p>
  </Section>

  <!-- Final CTA -->
  <Section spacing="loose" surface="graphite">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-12">
      <div class="md:col-span-3">
        <Eyebrow>08 · Talk to us</Eyebrow>
      </div>
      <div class="md:col-span-9">
        <h2 class="max-w-readable">
          Enterprise video.<br />Built for impact.
        </h2>
        <p class="mt-4 max-w-readable text-body text-gray">
          AI-native production. Human craft. Launch-ready in 48 hours.
        </p>
        <div class="mt-6 flex flex-wrap items-center gap-4">
          <Button variant="primary" href={contact.calendly}>
            Book a call →
          </Button>
          <Button variant="secondary" href="/portfolio">
            Review portfolio
          </Button>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
