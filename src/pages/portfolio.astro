---
/**
 * /portfolio — Agency-facing landing page.
 * Per outline §7: craft-led hero, filterable grid, big-brand logo wall,
 * case studies, agency testimonials, white-label CTA.
 *
 * TODO: implement filter logic, modal/case study routing, real assets.
 */
import BaseLayout from '@layouts/BaseLayout.astro';
import Section from '@components/ui/Section.astro';
import Eyebrow from '@components/ui/Eyebrow.astro';
import Button from '@components/ui/Button.astro';
import Container from '@components/layout/Container.astro';
import { contact } from '@lib/config';

// All client brands, alphabetical-ish. Replace with real SVG logos.
const allBrands = [
  'Aramco', 'Hilti', 'Roche', 'Bayer', 'Pfizer', 'Daikin', 'AWS', 'Outpost24',
  'Alacriti', 'Santen', 'Sherwin Williams', 'R3', 'TF Kable', 'Harris Health',
  'BT', 'KPMG', 'Paramount', 'MTV',
];
---

<BaseLayout
  title="Selected work"
  description="Selected work across sectors. Premium video, motion design and animation for B2B brands."
>
  <!-- Hero -->
  <section class="relative isolate min-h-[60vh] overflow-hidden bg-black">
    <Container as="div">
      <div class="flex min-h-[60vh] flex-col justify-end pb-12 pt-16">
        <p class="eyebrow">Selected work</p>
        <h1 class="mt-3 max-w-[18ch] text-offwhite">Selected work.</h1>
        <p class="mt-4 max-w-readable text-lead text-gray">
          Craft across sectors. Films, motion design, and animation for the
          brands listed below.
        </p>
      </div>
    </Container>
  </section>

  <!-- Trust strip / brand wall -->
  <Section spacing="loose" surface="graphite">
    <Eyebrow>Trusted by</Eyebrow>
    <h2 class="mt-3 max-w-readable">Brands that hold the line.</h2>

    <ul class="mt-8 grid grid-cols-2 gap-px overflow-hidden border border-gray-15 bg-gray-15 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6">
      {
        allBrands.map((b) => (
          <li class="flex items-center justify-center bg-graphite px-4 py-6 font-display text-h3 uppercase tracking-wide-label text-offwhite/80 transition-opacity duration-micro hover:opacity-100">
            {b}
          </li>
        ))
      }
    </ul>
  </Section>

  <!-- Filter + grid (placeholder) -->
  <Section spacing="loose">
    <Eyebrow>Work</Eyebrow>
    <h2 class="mt-3 max-w-readable">Filter by service or sector.</h2>
    <p class="mt-4 max-w-readable text-body text-gray">
      TODO: build filter UI and case study grid. Use SectorCaseGrid as a starting
      pattern. Each tile opens a case study or Vimeo modal.
    </p>
  </Section>

  <!-- Agency CTA -->
  <Section spacing="loose" surface="graphite">
    <div class="grid grid-cols-1 gap-8 md:grid-cols-12">
      <div class="md:col-span-3">
        <Eyebrow>For agencies</Eyebrow>
      </div>
      <div class="md:col-span-9">
        <h2 class="max-w-readable">White-label production partner.</h2>
        <p class="mt-4 max-w-readable text-body text-gray">
          We work with agencies as a white-label production partner. Talk to us
          about overflow, specialist work, or retained capacity.
        </p>
        <div class="mt-6">
          <Button variant="primary" href={contact.calendly}>
            Talk to us →
          </Button>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
