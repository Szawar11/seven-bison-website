---
/**
 * Testimonial — Per outline §10.
 * Written testimonials are the heavy artillery for direct client conversion.
 * Star ratings are background noise. The quote with name/title/company carries weight.
 */
import Section from '../ui/Section.astro';
import Eyebrow from '../ui/Eyebrow.astro';

export interface Quote {
  text: string;
  name: string;
  title: string;
  company: string;
  /** Optional path to a small monochrome company logo */
  logo?: string;
}

export interface Props {
  eyebrow?: string;
  heading?: string;
  quotes: Quote[];
}

const { eyebrow = 'In their words', heading, quotes } = Astro.props;
---

<Section spacing="loose" surface="graphite">
  {
    (eyebrow || heading) && (
      <div class="mb-8 grid grid-cols-1 gap-8 md:grid-cols-12">
        <div class="md:col-span-3">
          <Eyebrow>{eyebrow}</Eyebrow>
        </div>
        {heading && (
          <div class="md:col-span-9">
            <h2 class="max-w-readable">{heading}</h2>
          </div>
        )}
      </div>
    )
  }

  <ul class="grid grid-cols-1 gap-8 md:grid-cols-2">
    {
      quotes.map((q) => (
        <li class="flex flex-col gap-4 border-t border-pink pt-6">
          <p class="pull-quote">
            &ldquo;{q.text}&rdquo;
          </p>
          <div class="flex items-center gap-3">
            {q.logo && (
              <img
                src={q.logo}
                alt={`${q.company} logo`}
                class="h-8 w-auto opacity-80"
                loading="lazy"
              />
            )}
            <div>
              <p class="text-body text-offwhite">{q.name}</p>
              <p class="text-caption text-gray">
                {q.title} · {q.company}
              </p>
            </div>
          </div>
        </li>
      ))
    }
  </ul>
</Section>
