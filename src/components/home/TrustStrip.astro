---
/**
 * TrustStrip — Outline §4.3
 * Thin band: Google rating · Clutch rating · 4-5 logos.
 * Reinforces credibility above the fold without competing with the hero.
 *
 * Logos are monochrome (off-white) on dark. Subtle hover reveal optional.
 */

export interface Props {
  google?: { rating: number; count: number };
  clutch?: { rating: number; count: number };
}

const {
  google = { rating: 5.0, count: 24 },
  clutch = { rating: 4.9, count: 18 },
} = Astro.props;

// TODO: replace text placeholders with actual SVG logos in /public/images/logos
const logos = ['BT', 'KPMG', 'AWS', 'Paramount', 'MTV'];
---

<section class="border-y border-gray-15 bg-black py-6">
  <div class="container-site">
    <div class="flex flex-col items-center justify-between gap-6 md:flex-row">
      <!-- Ratings -->
      <div class="flex items-center gap-6 text-caption text-gray">
        <span>
          <span class="text-pink">★</span>
          <span class="ml-1 text-offwhite">{google.rating.toFixed(1)}</span>
          <span class="ml-1">Google ({google.count})</span>
        </span>
        <span class="hairline-gray h-4 w-px"></span>
        <span>
          <span class="text-pink">★</span>
          <span class="ml-1 text-offwhite">{clutch.rating.toFixed(1)}</span>
          <span class="ml-1">Clutch ({clutch.count})</span>
        </span>
      </div>

      <!-- Logos — monochrome off-white -->
      <ul class="flex items-center gap-6 opacity-70">
        {
          logos.map((name) => (
            <li
              class="font-display text-h3 uppercase tracking-wide-label text-offwhite transition-opacity duration-micro hover:opacity-100"
              style="line-height: 1;"
            >
              {name}
            </li>
          ))
        }
      </ul>
    </div>
  </div>
</section>
