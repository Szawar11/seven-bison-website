---
import Container from '../layout/Container.astro';

export interface Props {
  /** Spacing variant — controls vertical padding */
  spacing?: 'tight' | 'default' | 'loose' | 'hero';
  /** Surface background */
  surface?: 'black' | 'graphite' | 'charcoal';
  class?: string;
  id?: string;
}

const {
  spacing = 'default',
  surface = 'black',
  class: className = '',
  id,
} = Astro.props;

const spacings = {
  tight: 'py-8 md:py-10',
  default: 'py-12 md:py-16',
  loose: 'py-16 md:py-20',
  hero: 'pt-8 pb-12 md:pt-12 md:pb-20',
} as const;

const surfaces = {
  black: 'bg-black',
  graphite: 'bg-graphite',
  charcoal: 'bg-charcoal',
} as const;
---

<section id={id} class:list={[spacings[spacing], surfaces[surface], className]}>
  <Container>
    <slot />
  </Container>
</section>
